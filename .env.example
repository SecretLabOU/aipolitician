# HuggingFace API key with access to:
# - mistralai/Mistral-7B-Instruct-v0.2
# - Trump dataset
HUGGINGFACE_API_KEY=your_key_here

# Path where models will be saved/loaded
# Default: /home/shared_models/aipolitician
SHARED_MODELS_PATH=/path/to/models

# AI Politician Environment Configuration

# Hugging Face API Token (required for model download)
HF_TOKEN=your_hugging_face_token_here

# Model Configuration
BASE_MODEL=mistralai/Mistral-7B-Instruct-v0.2
TRUMP_MODEL_PATH=nnat03/trump-mistral-adapter
BIDEN_MODEL_PATH=nnat03/biden-mistral-adapter
DEFAULT_PERSONA=trump
MODEL_MAX_LENGTH=2048  # Increased for better context handling
MODEL_TEMPERATURE=0.7
MODEL_CACHE_DIR=./models

# GPU Configuration
CUDA_VISIBLE_DEVICES=0,1  # RTX 4060 Ti (ID 0), RTX 4090 (ID 1)
PRIMARY_GPU=1  # RTX 4090 for main model
SECONDARY_GPU=0  # RTX 4060 Ti for embeddings
GPU_MEMORY_UTILIZATION=0.92  # High memory utilization for RTX 4090
OFFLOAD_UNUSED_LAYERS=true  # Offloads unused layers to CPU when not in use
ENABLE_KERNL_ATTENTION=true  # Use FlashAttention2 kernels

# RAG System Configuration
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_USER=
MILVUS_PASSWORD=
MILVUS_COLLECTION=political_facts
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5  # Upgraded to larger embedding model
EMBEDDING_DIMENSION=1024
HYBRID_SEARCH_ALPHA=0.6  # Weight for hybrid search (dense vs sparse)

# CLI Configuration
CLI_SAVE_HISTORY=true
CLI_HISTORY_DIR=./chat_logs
CLI_STREAM_OUTPUT=true

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=8  # Increased for higher throughput
API_DEBUG=false
ENABLE_API_KEY=true  # Enabled for production security
API_KEY_NAME=X-API-Key
API_KEY=dev_key_change_me_in_production
MAX_CONCURRENT_REQUESTS=32  # Increased for RTX 4090
STREAM_RESPONSE=true  # Stream tokens for better UX

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
ENABLE_TELEMETRY=true  # Collect anonymous performance data

# Performance Settings
USE_TORCH_COMPILE=true  # Use PyTorch 2.0+ compiler for faster inference
USE_BETTERTRANSFORMER=true  # Use BetterTransformer for optimized attention
USE_AWQ=true  # Activation-aware weight quantization (4-bit)
AWQ_PRECISION=4  # 4-bit quantization
USE_INT8_KV_CACHE=true  # 8-bit KV cache for memory savings
MODEL_CACHE_CAPACITY=2  # Keep 2 models in memory
KV_CACHE_PRECISION=half  # Use half precision for KV cache
ENABLE_VLLM=true  # Use VLLM for high-throughput inference
SLIDING_WINDOW=4096  # Large sliding window for efficient attention
PAGE_ATTENTION=true  # Enable paged attention for memory efficiency
SCHEDULER=power  # Power scheduler for dynamic batch sizes
ENABLE_CONTINUOUS_BATCHING=true  # Enable continuous batching
MAX_TOKENS_PER_BATCH=16384  # Maximize tokens per batch
BATCH_SIZE_TOKEN_RATIO=100  # Dynamic batch sizing
MAX_BATCH_PREFILL_TOKENS=4096  # Maximum tokens to prefill
USE_TENSOR_PARALLEL=true  # Enable model parallelism
TENSOR_PARALLEL_SIZE=2  # Use both GPUs for tensor parallelism
TP_OVERLAP=true  # Enable tensor parallel communication overlap
ROPE_SCALING=dynamic  # Dynamic RoPE scaling for extended context

# Prometheus metrics
ENABLE_PROMETHEUS=true
PROMETHEUS_PORT=9090
COLLECT_GPU_METRICS=true  # Collect detailed GPU metrics
